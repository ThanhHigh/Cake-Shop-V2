{
  "name": "cake-shop/training-lab",
  "description": "OWASP Training Lab - Vulnerable PHP E-Commerce System",
  "type": "project",
  "license": "MIT",
  "require": {
    "php": ">=7.4",
    "ext-pdo": "*",
    "ext-json": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.5",
    "squizlabs/php_codesniffer": "^3.6"
  },
  "autoload": {
    "psr-4": {
      "CakeShop\\": "src/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "lint": "phpcs src/",
    "server": "php -S localhost:8000 -t public/"
  }
}
